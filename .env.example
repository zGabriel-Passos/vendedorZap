# =========================================================
# Vendedor Zap - exemplo de variaveis de ambiente
# =========================================================
# PASSO A PASSO
# 1. Renomeie este arquivo de ".env.example" para ".env"
# 2. Preencha cada variavel abaixo com as suas chaves reais
# 3. Salve o arquivo e rode "npm run dev"
#
# Dica:
# - Variaveis com prefixo NEXT_PUBLIC_ podem aparecer no cliente.
# - Chaves sem NEXT_PUBLIC_ devem permanecer privadas.
#
# =========================================================
# FIREBASE
# =========================================================
# Onde pegar:
# 1. Acesse https://console.firebase.google.com/
# 2. Crie um projeto ou abra um existente
# 3. Va em Configuracoes do projeto > Seus apps > Web app
# 4. Copie os valores do objeto de configuracao do SDK

NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID

# Opcional: o codigo atual nao usa essa variavel diretamente.
# Mantenha apenas se voce quiser guardar a configuracao completa do app.
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=YOUR_FIREBASE_MEASUREMENT_ID

# =========================================================
# GROQ
# =========================================================
# Onde pegar:
# 1. Acesse https://console.groq.com/
# 2. Crie sua conta ou faca login
# 3. Gere uma API key
# 4. Cole a chave abaixo

GROQ_API_KEY=YOUR_GROQ_API_KEY

# =========================================================
# ABACATEPAY
# =========================================================
# Onde pegar:
# 1. Acesse https://abacatepay.com/ ou https://docs.abacatepay.com/
# 2. Crie sua conta ou faca login
# 3. Gere uma chave de API no painel
# 4. Cole a chave abaixo

ABACATEPAY_API_KEY=YOUR_ABACATEPAY_API_KEY

# =========================================================
# URL BASE DA APLICACAO
# =========================================================
# Usada para callbacks e links de retorno do pagamento.
# Em desenvolvimento: http://localhost:3000
# Em producao: substitua pela URL publica do deploy

NEXTAUTH_URL=http://localhost:3000

# =========================================================
# WHATSAPP
# =========================================================
# WHATSAPP_VERIFY_TOKEN:
# - Opcional neste projeto
# - Usado apenas pela rota app/api/webhook/whatsapp/route.ts
# - Defina qualquer string segura se for usar verificacao de webhook

WHATSAPP_VERIFY_TOKEN=YOUR_WHATSAPP_VERIFY_TOKEN

# MY_WHATSAPP_ID:
# - Numero autorizado para conversar com o bot
# - Formato esperado: apenas numeros, com DDI e DDD
# - Exemplo: 5511999999999

MY_WHATSAPP_ID=5511999999999
